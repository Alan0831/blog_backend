ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIOSS_REGION=oss-cn-beijing
ALIOSS_BUCKET=commit-alan
REQUEST_BODY_LIMIT=10mb

# 视频切片资源控制：小规格服务器建议保持默认值
FFMPEG_MAX_CONCURRENT=1
FFMPEG_THREADS=1
FFMPEG_COPY_WHEN_COMPATIBLE=true
FFMPEG_COPY_MAX_HEIGHT=1080
FFMPEG_MAX_OUTPUT_HEIGHT=720
FFMPEG_ENABLE_MULTI_RENDITION=false
FFMPEG_PRESET=superfast
FFMPEG_CRF=26
HLS_SEGMENT_DURATION=6

# 非白名单 IP 访问接口时发送邮件（按 IP 冷却去重）
IP_ALERT_ENABLED=false
IP_ALERT_ALLOWED_IPS=140.206.194.4
IP_ALERT_COOLDOWN_MINUTES=60
IP_ALERT_API_PREFIX=/commit/api
IP_ALERT_SMTP_HOST=smtp.163.com
IP_ALERT_SMTP_PORT=465
IP_ALERT_SMTP_SECURE=true
IP_ALERT_SMTP_USER=
IP_ALERT_SMTP_PASS=
IP_ALERT_FROM=
IP_ALERT_TO=
IP_ALERT_SUBJECT=博客接口收到新 IP 访问
